# App
APP_ENV=development
SECRET_KEY=development_secret_key_change_me

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@postgres:5432/soc_copilot
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=soc-copilot

# LLM
OLLAMA_BASE_URL=http://ollama:11434
LLM_DEFAULT_PROVIDER=omniroute

# Pipeline
MAX_CONCURRENT_INVESTIGATIONS=3
MAX_FILE_SIZE_MB=100
TI_CACHE_TTL_SECONDS=3600

# Feature Flags
OFFLINE_MODE=false
CLAMAV_ENABLED=false

# External Providers (Placeholders)
# OMNIROUTE_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# GEMINI_API_KEY=

# Data Seeds
MITRE_STIX_PATH=/data/mitre/enterprise-attack.json
